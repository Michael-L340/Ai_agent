# ===== 基础 =====
APP_NAME=ai-invest-agent
API_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Asia/Shanghai
# PostgreSQL connection string.
# You can put it here or keep using F:\AI_Agent\postgresSQL\.env.
DATABASE_URL=

# ===== 调度 =====
FULL_CYCLE_MINUTES=30
RECOMMEND_SCORE_THRESHOLD=75
DAILY_STRATEGY_FILE=./data/daily_strategy.txt

# ===== Webhook（可选）=====
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=10
OPENCLAW_WEBHOOK_SECRET=
OPENCLAW_WEBHOOK_PATH=/openclaw/inbox
OPENCLAW_OUTBOX_PATH=/openclaw/outbox

# ===== LLM（可选，没填也能跑规则版）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ===== 搜索 API =====
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
BOCHA_API_KEY=
BOCHA_SEARCH_URL=https://api.bochaai.com/v1/web-search

# ===== 演示模式 =====
DEMO_MODE=false

